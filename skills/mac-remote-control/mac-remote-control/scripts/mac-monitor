#!/bin/bash
# Mac agent monitoring with Telegram alerts
set -euo pipefail

TELEGRAM_BOT_TOKEN="8601864128:AAE-a0Lnv8bhBq78r232l7EgNKVWtF4MTMc"
TELEGRAM_CHAT_ID="8305273339"
ALERT_LOG="/tmp/mac-monitor-alerts.log"

send_alert() {
  local msg="$1"
  echo "[$(date '+%F %T')] ALERT: $msg" >> "$ALERT_LOG"
  curl -s -X POST "https://api.telegram.org/bot${TELEGRAM_BOT_TOKEN}/sendMessage" \
    -d "chat_id=${TELEGRAM_CHAT_ID}" \
    -d "text=🚨 Mac Agent Alert: $msg" \
    -d "parse_mode=HTML" > /dev/null 2>&1 || true
}

# 1. Check agent online
agents_json=$(curl -s http://154.40.43.33:8080/api/agents)
mac_online=$(echo "$agents_json" | jq -r '.[] | select(.id=="mac") | .online')

if [ "$mac_online" != "true" ]; then
  send_alert "Mac agent is OFFLINE"
  exit 1
fi

# 2. Check exec capability
test_result=$(/usr/local/bin/mac echo "monitor-ok" 2>&1) || {
  send_alert "Mac agent registered but exec failed: $test_result"
  exit 1
}

if [ "$test_result" != "monitor-ok" ]; then
  send_alert "Mac agent exec returned unexpected: $test_result"
  exit 1
fi

# 3. Check heartbeat freshness
last_hb=$(echo "$agents_json" | jq -r '.[] | select(.id=="mac") | .lastHeartbeat')
now=$(date +%s)
age=$((now - last_hb))

if [ $age -gt 120 ]; then
  send_alert "Mac agent heartbeat is stale (${age}s ago)"
  exit 1
fi

echo "[$(date '+%F %T')] Mac agent healthy (heartbeat ${age}s ago)" >> "$ALERT_LOG"
exit 0
